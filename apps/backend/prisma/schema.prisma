generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  LOAN_OFFICER
  REVIEWER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  PENDING_DOCUMENTS
  DOCUMENT_VERIFICATION
  APPROVED
  REJECTED
  DISBURSED
  CLOSED
}

enum LoanType {
  PERSONAL
  MORTGAGE
  AUTO
  BUSINESS
  DEBT_CONSOLIDATION
  OTHER
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum HousingStatus {
  OWNER
  RENTER
  FAMILY
  OTHER
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  RETIRED
  STUDENT
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  PART_TIME
  FREELANCE
  OTHER
}

enum DocumentCategory {
  ID_CARD
  PASSPORT
  DRIVER_LICENSE
  INCOME_PROOF
  PAYSLIP
  BANK_STATEMENT
  TAX_DOCUMENT
  RESIDENCE_PROOF
  GUARANTOR_ID
  GUARANTOR_INCOME
  COLLATERAL_DOC
  OTHER
}

enum DocumentStatus {
  PENDING
  RECEIVED
  VERIFIED
  REJECTED
  EXPIRED
}

enum CollateralType {
  REAL_ESTATE
  VEHICLE
  JEWELRY
  SAVINGS
  OTHER
}

enum NotificationType {
  STATUS_CHANGE
  DOCUMENT_UPLOADED
  DOCUMENT_MISSING
  GOOGLE_DOC_UPDATED
  CASE_ASSIGNED
  NOTE_ADDED
  GENERAL
}

// ─── Models ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(LOAN_OFFICER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignments            ApplicationAssignment[]
  internalNotes          InternalNote[]
  activityLogs           ActivityLog[]
  notifications          Notification[]
  uploadedDocuments      UploadedDocument[]
  googleConnections      GoogleConnection[]
  linkedGoogleDocs       LinkedGoogleDocument[]
  statusChanges          StatusHistory[]
  consentsRecorded       ConsentRecord[]
  applicationsAssigned   ApplicationAssignment[] @relation("AssignedApplications")

  @@map("users")
}

model Applicant {
  id              String         @id @default(uuid()) @db.Uuid
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  codiceFiscale   String         @unique @map("codice_fiscale")
  birthDate       DateTime       @map("birth_date")
  birthPlace      String?        @map("birth_place")
  nationality     String         @default("Italiana")
  maritalStatus   MaritalStatus  @default(SINGLE) @map("marital_status")
  dependents      Int            @default(0)
  phone           String
  email           String
  idDocType       String?        @map("id_doc_type")
  idDocNumber     String?        @map("id_doc_number")
  idDocExpiry     DateTime?      @map("id_doc_expiry")
  address         String
  city            String
  province        String
  postalCode      String         @map("postal_code")
  country         String         @default("Italia")
  housingStatus   HousingStatus  @default(OTHER) @map("housing_status")
  yearsAtAddress  Int?           @map("years_at_address")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  applications LoanApplication[]

  @@index([lastName, firstName])
  @@index([codiceFiscale])
  @@map("applicants")
}

model LoanApplication {
  id               String            @id @default(uuid()) @db.Uuid
  status           ApplicationStatus @default(DRAFT)
  loanType         LoanType          @default(PERSONAL) @map("loan_type")
  requestedAmount  Decimal           @map("requested_amount") @db.Decimal(12, 2)
  loanPurpose      String            @map("loan_purpose")
  durationMonths   Int               @map("duration_months")
  monthlyInstallment Decimal?        @map("monthly_installment") @db.Decimal(10, 2)
  disbursementDate DateTime?         @map("disbursement_date")
  urgency          UrgencyLevel      @default(MEDIUM)
  notes            String?
  googleDocId      String?           @map("google_doc_id")
  googleFileId     String?           @map("google_file_id")
  linkedByUserId   String?           @map("linked_by_user_id")
  linkedAt         DateTime?         @map("linked_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  applicant        Applicant          @relation(fields: [applicantId], references: [id])
  applicantId      String             @map("applicant_id") @db.Uuid
  employment       EmploymentInfo?
  financialProfile FinancialProfile?
  guarantors       Guarantor[]
  collaterals      Collateral[]
  documents        UploadedDocument[]
  notes            InternalNote[]
  activityLogs     ActivityLog[]
  notifications    Notification[]
  statusHistory    StatusHistory[]
  consents         ConsentRecord[]
  assignments      ApplicationAssignment[]
  watchChannels    DocumentWatchChannel[]

  @@index([status])
  @@index([applicantId])
  @@index([createdAt])
  @@map("loan_applications")
}

model EmploymentInfo {
  id                String          @id @default(uuid()) @db.Uuid
  status            EmploymentStatus @default(EMPLOYED)
  employer          String?
  jobTitle          String?         @map("job_title")
  contractType      ContractType?   @map("contract_type")
  startDate         DateTime?       @map("start_date")
  monthsEmployed    Int?            @map("months_employed")
  monthlyNetIncome  Decimal?        @map("monthly_net_income") @db.Decimal(10, 2)
  monthlyGrossIncome Decimal?       @map("monthly_gross_income") @db.Decimal(10, 2)
  otherIncome       Decimal?        @map("other_income") @db.Decimal(10, 2)
  isSelfEmployed    Boolean         @default(false) @map("is_self_employed")
  vatNumber         String?         @map("vat_number")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @unique @map("application_id") @db.Uuid

  @@map("employment_info")
}

model FinancialProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  monthlyHousingCost  Decimal? @map("monthly_housing_cost") @db.Decimal(10, 2)
  monthlyExpenses     Decimal? @map("monthly_expenses") @db.Decimal(10, 2)
  existingLoans       Decimal? @map("existing_loans") @db.Decimal(12, 2)
  totalMonthlyDebt    Decimal? @map("total_monthly_debt") @db.Decimal(10, 2)
  totalExistingDebt   Decimal? @map("total_existing_debt") @db.Decimal(12, 2)
  bankName            String?  @map("bank_name")
  iban                String?
  savings             Decimal? @db.Decimal(12, 2)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @unique @map("application_id") @db.Uuid

  @@map("financial_profiles")
}

model Guarantor {
  id            String   @id @default(uuid()) @db.Uuid
  fullName      String   @map("full_name")
  codiceFiscale String?  @map("codice_fiscale")
  phone         String?
  email         String?
  address       String?
  relationship  String?
  employment    String?
  income        Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @map("application_id") @db.Uuid

  @@map("guarantors")
}

model Collateral {
  id               String        @id @default(uuid()) @db.Uuid
  type             CollateralType
  description      String?
  estimatedValue   Decimal?      @map("estimated_value") @db.Decimal(12, 2)
  ownershipStatus  String?       @map("ownership_status")
  registrationNumber String?     @map("registration_number")
  insuranceInfo    String?       @map("insurance_info")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @map("application_id") @db.Uuid

  @@map("collaterals")
}

model UploadedDocument {
  id            String           @id @default(uuid()) @db.Uuid
  documentType  DocumentCategory @map("document_type")
  fileName      String           @map("file_name")
  filePath      String           @map("file_path")
  fileSize      Int              @map("file_size")
  mimeType      String           @map("mime_type")
  status        DocumentStatus   @default(PENDING)
  rejectionReason String?        @map("rejection_reason")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @map("application_id") @db.Uuid
  uploadedBy    User            @relation(fields: [uploadedById], references: [id])
  uploadedById  String          @map("uploaded_by_id") @db.Uuid

  @@index([applicationId])
  @@map("uploaded_documents")
}

model GoogleConnection {
  id           String   @id @default(uuid()) @db.Uuid
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  tokenExpiry  DateTime @map("token_expiry")
  googleEmail  String?  @map("google_email")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @map("user_id") @db.Uuid

  @@map("google_connections")
}

model LinkedGoogleDocument {
  id           String   @id @default(uuid()) @db.Uuid
  googleDocId  String   @map("google_doc_id")
  googleFileId String   @map("google_file_id")
  lastSyncedAt DateTime? @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @map("application_id") @db.Uuid
  linkedBy      User            @relation(fields: [linkedById], references: [id])
  linkedById    String          @map("linked_by_id") @db.Uuid

  @@unique([applicationId])
  @@map("linked_google_documents")
}

model DocumentWatchChannel {
  id           String    @id @default(uuid()) @db.Uuid
  channelId    String    @unique @map("channel_id")
  resourceId   String?   @map("resource_id")
  expiration   DateTime
  syncToken    String?   @map("sync_token")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String          @map("application_id") @db.Uuid

  @@index([channelId])
  @@index([active, expiration])
  @@map("document_watch_channels")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String           @map("user_id") @db.Uuid
  application     LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String?          @map("application_id") @db.Uuid

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id])
  userId          String           @map("user_id") @db.Uuid
  application     LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String?          @map("application_id") @db.Uuid

  @@index([applicationId, createdAt])
  @@map("activity_logs")
}

model InternalNote {
  id        String   @id @default(uuid()) @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  userId          String           @map("user_id") @db.Uuid
  application     LoanApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String           @map("application_id") @db.Uuid

  @@index([applicationId, createdAt])
  @@map("internal_notes")
}

model ConsentRecord {
  id            String   @id @default(uuid()) @db.Uuid
  consentType   String   @map("consent_type")
  granted       Boolean
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  application     LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String          @map("application_id") @db.Uuid
  recordedBy      User            @relation(fields: [recordedById], references: [id])
  recordedById    String          @map("recorded_by_id") @db.Uuid

  @@map("consent_records")
}

model StatusHistory {
  id         String            @id @default(uuid()) @db.Uuid
  fromStatus ApplicationStatus? @map("from_status")
  toStatus   ApplicationStatus  @map("to_status")
  reason     String?
  createdAt  DateTime          @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id])
  userId          String           @map("user_id") @db.Uuid
  application     LoanApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String           @map("application_id") @db.Uuid

  @@index([applicationId, createdAt])
  @@map("status_history")
}

model ApplicationAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user            User             @relation(fields: [userId], references: [id])
  userId          String           @map("user_id") @db.Uuid
  application     LoanApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId   String           @map("application_id") @db.Uuid

  @@unique([applicationId])
  @@map("application_assignments")
}
