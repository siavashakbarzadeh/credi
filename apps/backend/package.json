    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.31.0",
    "fastify": "^5.2.1",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
