NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://credi_user:credi_password@localhost:5432/credi_db?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_WEBHOOK_ADDRESS=http://localhost:3001/api/webhooks/google-drive

# Production (Railway):
# BACKEND_URL=https://your-backend.up.railway.app
# FRONTEND_URL=https://your-app.vercel.app
#
# NOTE: GOOGLE_REDIRECT_URI is now constructed automatically from BACKEND_URL
# Callback URLs registered in Google Cloud Console must match:
#   https://your-backend.up.railway.app/api/auth/google/callback        (Docs connection)
#   https://your-backend.up.railway.app/api/auth/google/login/callback   (Google Login)
