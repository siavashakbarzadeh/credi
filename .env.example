NODE_ENV=development

# PostgreSQL
POSTGRES_USER=credi_user
POSTGRES_PASSWORD=credi_password
POSTGRES_DB=credi_db
DATABASE_URL=postgresql://credi_user:credi_password@localhost:5432/credi_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Backend
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Google Webhook
GOOGLE_WEBHOOK_ADDRESS=http://localhost:3001/api/webhooks/google-drive
